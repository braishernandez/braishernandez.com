# ── REWRITE ───────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Excluir endpoints de API directos
    RewriteRule ^video_api\.php$ - [L]

    # Si el archivo o directorio existe, servir directamente
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás va a index.php
    RewriteRule ^ index.php [L]
</IfModule>

# ── SEGURIDAD ─────────────────────────────────────────────────────────────────
# Ocultar archivos sensibles
<FilesMatch "\.(env|log|sh|sql|json|lock|md|gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Deshabilitar listado de directorios
Options -Indexes

# ── COMPRESIÓN GZIP ───────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ── CACHÉ DE ASSETS ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg           "access plus 1 month"
    ExpiresByType image/png            "access plus 1 month"
    ExpiresByType image/webp           "access plus 1 month"
    ExpiresByType font/woff2           "access plus 1 year"
</IfModule>

# ── TIPOS DE FUENTES ──────────────────────────────────────────────────────────
AddType font/woff2 .woff2
AddType application/font-woff .woff
<IfModule mod_headers.c>
    <FilesMatch "\.(ttf|otf|eot|woff|woff2)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ── ERRORES ───────────────────────────────────────────────────────────────────
ErrorDocument 404 /index.php
